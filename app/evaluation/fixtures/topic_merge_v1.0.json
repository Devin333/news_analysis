{
  "name": "Topic Merge Evaluation",
  "version": "1.0",
  "evaluation_type": "topic_merge",
  "metadata": {
    "description": "Samples for topic merge precision/recall evaluation",
    "created_at": "2024-01-01"
  },
  "samples": [
    {
      "id": "tm_001",
      "input": {
        "topic_a": {
          "id": 1,
          "title": "GPT-5 Release Announcement",
          "items": ["OpenAI announces GPT-5", "GPT-5 features revealed"]
        },
        "topic_b": {
          "id": 2,
          "title": "OpenAI GPT-5 Launch",
          "items": ["GPT-5 launched today", "New GPT model from OpenAI"]
        }
      },
      "expected": {
        "should_merge": true,
        "reason": "Same event - GPT-5 release"
      },
      "tags": ["duplicate", "ai"]
    },
    {
      "id": "tm_002",
      "input": {
        "topic_a": {
          "id": 3,
          "title": "React 19 Release",
          "items": ["React 19 announced with new features"]
