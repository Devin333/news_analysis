        "topic_b": {
          "id": 4,
          "title": "Vue 4 Release",
          "items": ["Vue 4 released with composition API improvements"]
        }
      },
      "expected": {
        "should_merge": false,
        "reason": "Different frameworks"
      },
      "tags": ["distinct", "frontend"]
    },
    {
